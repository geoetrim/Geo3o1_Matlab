# ── 1) Loading the libraries ──────────────────────────────────────────────────
!pip install plotly scipy -q

import scipy.io as sio
import numpy as np
import plotly.graph_objects as go
from google.colab import files
print('✅ Kütüphaneler hazır.')

import IPython

# ── 2) Loading the .mat file ─────────────────────────────────────────────────
uploaded = files.upload()
mat_filename = list(uploaded.keys())[0]
print(f'📂 Loaded file: {mat_filename}')

# ── 3) Importing the data ───────────────────────────────────────────────────────────
mat = sio.loadmat(mat_filename)
print('📦 Variables in the file:', [k for k in mat.keys() if not k.startswith('_')])
for k in mat.keys():
    if not k.startswith('_'):
        print(f'  {k}: shape={np.array(mat[k]).shape}')

# ── 4) Set pltv3d parameters ────────────────────────────────────────
# process_id:
#   0 = Direct georeferencing (raw viewing angles + EOP)
#   1 = Pre-adjustment
#   2 = Bundle adjustment
process_id = 2

# Sensor name: if 'S6_SENSOR' then divider=40, otherwise 10
sensor_name = 'OTHER'   # 'S6_SENSOR' or 'OTHER'

divider = 40 if sensor_name == 'S6_SENSOR' else 10
if process_id == 0:
  print(f'⚙️  Graphics for direct georeferencing.')
elif process_id == 1:
  print(f'⚙️  Graphics for pre-adjustment.')
else:
  print(f'⚙️  Graphics for bundle adjustment.')

# ── 5) Extract variables ───────────────────────────────────────────────────
# MATLAB 1-index → Python 0-index difference has been taken into account

# points column map (MATLAB → Python):
#  1→0  : Point ID
#  4→3  : X reference coordinate
#  5→4  : Y reference coordinate
#  6→5  : Z reference coordinate
# 13→12 : X calculated coordinate (GCP)
# 14→13 : Y calculated coordinate (GCP)
# 15→14 : Z calculated coordinate (GCP)

if process_id == 0:
    points_data = mat['points_direct'][:, :, 0] # Use only the first image's data
    gcp = points_data   # For direct georeferencing, all points are treated as GCPs
    # Initialize empty ICP arrays to prevent NameError in plotting section
    icp = np.array([])
else:
    points_data = mat['points'][:, :, 0] # Use only the first image's data
    # If Sc (GCP/ICP separation) is in the mat file:
    if 'Sc' in mat:
        # Sc contains 1-based ICP point IDs. points[:, 0, 0] also contains 1-based Point IDs.
        icp_point_ids = mat['Sc'].flatten().astype(int)
        all_point_ids = points_data[:, 0].astype(int)

        is_icp_mask = np.isin(all_point_ids, icp_point_ids)

        gcp = points_data[~is_icp_mask, :]
        icp = points_data[is_icp_mask, :]
    else:
        gcp = points_data
        icp = np.array([]) # No ICP points found
        print('⚠️  Sc not found, all points are used as GCP.')

# GCP Coordinates
X_ref_gcp = gcp[:, 3]
Y_ref_gcp = gcp[:, 4]
Z_ref_gcp = gcp[:, 5]

X_calc_gcp = gcp[:, 12]
Y_calc_gcp = gcp[:, 13]
Z_calc_gcp = gcp[:, 14]
IDs   = gcp[:, 0].astype(int)

# ICP Coordinates (if any)
X_ref_icp = np.array([])
Y_ref_icp = np.array([])
Z_ref_icp = np.array([])
X_calc_icp = np.array([])
Y_calc_icp = np.array([])
Z_calc_icp = np.array([])

if icp.size > 0:
    X_ref_icp = icp[:, 3]
    Y_ref_icp = icp[:, 4]
    Z_ref_icp = icp[:, 5]

    X_calc_icp = icp[:, 12]
    Y_calc_icp = icp[:, 13]
    Z_calc_icp = icp[:, 14]

# Residuals
if 'dgcp' in mat:
    dgcp = mat['dgcp']          # get directly from file
elif 'dp_direct' in mat and process_id == 0:
    dgcp = mat['dp_direct']
elif 'dgcp_pre' in mat and process_id == 1:
    dgcp = mat['dgcp_pre']
    dicp = mat['dicp_pre']
elif 'dgcp_bundle' in mat and process_id == 2:
    dgcp = mat['dgcp_bundle']
    dicp = mat['dicp_bundle']

# ── 6) Calculate scale (based on provided MATLAB logic) ─────────────────────

# Determine mgcp_val based on process_id
mgcp_val = None
if process_id == 0:
    mgcp_val = mat['mdg_direct']
elif process_id == 1:
    mgcp_val = mat['mdg']
elif process_id == 2:
    mgcp_val = mat['mgcp']
    if 'number_images' in mat and mat['number_images'].item() == 3:
        # Assuming 'mgcp_triplet' might exist in mat, otherwise use 'mgcp'
            mgcp_val = mat['mgcp_triplet']

# Ensure mgcp_val is not None/empty before calculation
if mgcp_val is not None and mgcp_val.size > 0:
    # Calculate mo_gcp (sum of squares for a 1x3 vector)
    mo_gcp = np.sqrt(np.sum(mgcp_val[0]**2))
else:
    print("Error: mgcp_val could not be determined or is empty. Setting mo_gcp to 0.")
    mo_gcp = 0.0

# Calculate x_range (this part remains the same as it's a general range)
points = mat['points']
x_range = float(points[:, 3, 0].max() - points[:, 3, 0].min())

# Calculate scale_gcp
scale_gcp = x_range / (divider * mo_gcp) if mo_gcp != 0 else 0.0

print(f'📏 mo (GCP)   : {mo_gcp:.4f} m')
print(f'📏 Scale (GCP): {scale_gcp:.2f} m')

# U, V, W use dgcp (residuals from extract cell) and the newly calculated scale_gcp
U = scale_gcp * dgcp[:, 0]
V = scale_gcp * dgcp[:, 1]
W = scale_gcp * dgcp[:, 2]

# Calculate mo_icp and scale_icp if process_id > 0
mo_icp = 0.0 # Initialize mo_icp
scale_icp = 0.0 # Initialize scale_icp
if process_id > 0:
    micp_val = None
    if process_id == 1:
        micp_val = mat['mdi']
    elif process_id == 2:
        micp_val = mat['micp']

    # Ensure micp_val is not None/empty before calculation
    if micp_val is not None and micp_val.size > 0:
        # Calculate mo_icp (sum of squares for a 1x3 vector)
        mo_icp = np.sqrt(np.sum(micp_val[0]**2))
        # Calculate scale_icp
        scale_icp = x_range / (divider * mo_icp) if mo_icp != 0 else 0.0
        print(f'📏 mo (ICP)   : {mo_icp:.4f} m')
        print(f'📏 Scale (ICP): {scale_icp:.2f} m')
    else:
        print("Error: micp_val could not be determined or is empty. Setting mo_icp and scale_icp to 0.")

# Scale arrow position
sx = float(points[:, 3, 0].max())
sy = float(points[:, 4, 0].min())
sz = float(points[:, 5, 0].max())
su = x_range / divider
print(f'✅ Scale arrow length: {su:.2f} m → represents: {mo_gcp:.4f} m')

import plotly.graph_objects as go
import numpy as np

titles = {
    0: 'Residuals for Direct Georeferencing',
    1: 'Residuals for Pre-Adjustment',
    2: 'Residuals for Bundle Adjustment'
}

mag = np.sqrt(U**2 + V**2 + W**2)
traces = []

# --- GCP points ---
# Markers should be at reference coordinates
hover_gcp = [(
    f'<b>GCP {IDs[i]}</b><br>'
    f'X_gcp: {X_calc_gcp[i]:.2f}<br>'
    f'Y_gcp: {Y_calc_gcp[i]:.2f}<br>'
    f'Z_gcp: {Z_calc_gcp[i]:.2f}<br>'
    f'dX: {dgcp[i,0]:.4f} m<br>'
    f'dY: {dgcp[i,1]:.4f} m<br>'
    f'dZ: {dgcp[i,2]:.4f} m'
) for i in range(len(X_ref_gcp))]

traces.append(go.Scatter3d(
    x=X_calc_gcp, y=Y_calc_gcp, z=Z_calc_gcp,
    mode='markers',
    marker=dict(
        size=1.33, symbol='circle',
        color='black',
        line=dict(color='black', width=0.5)
    ),
    hovertemplate=['%s<extra></extra>' % h for h in hover_gcp],
    name='GCP Reference Points'
))

# --- Residual vector lines (only straight line, no arrow head) ---
lx, ly, lz = [], [], []
for i in range(len(X_calc_gcp)):
    # Vectors originate from reference coordinates
    lx += [X_calc_gcp[i], X_calc_gcp[i]+U[i], None]
    ly += [Y_calc_gcp[i], Y_calc_gcp[i]+V[i], None]
    lz += [Z_calc_gcp[i], Z_calc_gcp[i]+W[i], None]

traces.append(go.Scatter3d(
    x=lx, y=ly, z=lz,
    mode='lines',
    line=dict(color='black', width=2),
    hoverinfo='skip',
    name='GCP Residual Vectors'
))

# --- Scale arrow ---
gcp_text = f'{mo_gcp:.2f} m for GCPs'
icp_text = ''
if 'mo_icp' in locals() and mo_icp > 0:
    gcp_text += ' and'
    icp_text = f' {mo_icp:.2f} m for ICPs'

full_scale_arrow_text = gcp_text + icp_text

hover_scale_text = f'mo_GCP = {mo_gcp:.2f} m'
if 'mo_icp' in locals() and mo_icp > 0:
    hover_scale_text += f'<br>mo_ICP = {mo_icp:.2f} m'

traces.append(go.Scatter3d(
    x=[sx, sx+su], y=[sy, sy], z=[sz, sz],
    mode='lines',
    line=dict(color='black', width=5),
    text=['', ''], # Removed text from directly on the plot
    textposition='middle right',
    textfont=dict(size=11, color='black'),
    name=f'Scale = {gcp_text.replace(" and", "")} {icp_text.strip()}',
    hovertemplate=f'<b>Scale arrow</b><br>{hover_scale_text}<extra></extra>'
))

# --- ICP points (if any) ---
if process_id > 0 and icp.size > 0:
    # ICP points markers should be at reference coordinates
    hover_icp = [(
        f'<b>ICP {int(icp[i, 0])}</b><br>' # Added ICP ID
        f'X_icp: {X_calc_icp[i]:.2f}<br>'
        f'Y_icp: {Y_calc_icp[i]:.2f}<br>'
        f'Z_icp: {Z_calc_icp[i]:.2f}<br>'
        f'dX: {dicp[i,0]:.4f} m<br>'
        f'dY: {dicp[i,1]:.4f} m<br>'
        f'dZ: {dicp[i,2]:.4f} m'
    ) for i in range(len(X_ref_icp))]

    # Removed the incorrect 'dicp' in mat check, as dicp variable is already populated
    # if process_id > 0 and icp.size > 0
    Ui = scale_icp * dicp[:, 0]
    Vi = scale_icp * dicp[:, 1]
    Wi = scale_icp * dicp[:, 2]

    lxi, lyi, lzi = [], [], []
    for i in range(len(X_calc_icp)):
        lxi += [X_calc_icp[i], X_calc_icp[i]+Ui[i], None]
        lyi += [Y_calc_icp[i], Y_calc_icp[i]+Vi[i], None]
        lzi += [Z_calc_icp[i], Z_calc_icp[i]+Wi[i], None]

    traces.append(go.Scatter3d(
        x=lxi, y=lyi, z=lzi,
        mode='lines', line=dict(color='blue', width=2),
        hoverinfo='skip', name='ICP Residual Vectors'
    ))
    traces.append(go.Scatter3d(
        x=X_calc_icp, y=Y_calc_icp, z=Z_calc_icp,
        mode='markers',
        marker=dict(size=3.5, color='blue', symbol='circle-open'),
        hovertemplate=['%s<extra></extra>' % h for h in hover_icp],
        name='ICP Reference Points'
    ))

# --- Layout ---
fig = go.Figure(data=traces)
fig.update_layout(
    title=dict(text=titles[process_id], font=dict(size=15)),
    scene=dict(
        xaxis=dict(title=dict(text='X (meter)'), showgrid=True, gridcolor='lightgray', backgroundcolor='white',
                   tickfont=dict(color='black', size=10), titlefont=dict(color='black'), showline=True, linecolor='black', nticks=6,
                   exponentformat='power', showexponent='all', mirror=True),
        yaxis=dict(title=dict(text='Y (meter)'), showgrid=True, gridcolor='lightgray', backgroundcolor='white',
                   tickfont=dict(color='black', size=10), titlefont=dict(color='black'), showline=True, linecolor='black', nticks=6,
                   exponentformat='power', showexponent='all', mirror=True),
        zaxis=dict(title=dict(text='Z (meter)'), showgrid=True, gridcolor='lightgray', backgroundcolor='white',
                   tickfont=dict(color='black', size=10), titlefont=dict(color='black'), showline=True, linecolor='black', nticks=6,
                   exponentformat='power', showexponent='all', mirror=True),
        aspectmode='data',
        camera=dict(eye=dict(x=1.4, y=1.4, z=1.1), projection=dict(type='orthographic')),
        bgcolor='white'
    ),
    legend=dict(x=0.01, y=0.98, bgcolor='rgba(255,255,255,0.8)')
    ,
    margin=dict(l=0, r=0, t=40, b=0),
    width=1000, height=700
)

fig.show()

# ── 8) Save and download as HTML (optional) ───────────────────────────
output_name = 'gcp_residuals_3d.html'
fig.write_html(output_name, include_plotlyjs='cdn')
files.download(output_name)
print(f'✅ {output_name} downloaded!')